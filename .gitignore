.env
.env.*
!.env.example
*.secret

# ---------------------------------------------------------------------------
# Jupyter Notebook
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# ---------------------------------------------------------------------------
# Data Science: data, models, artifacts
# (Keep raw data OUT of git — it's large and often license-restricted.
#  Track schema/sample files explicitly if needed.)
# ---------------------------------------------------------------------------
data/raw/
data/interim/
data/processed/
data/external/
*.csv
*.tsv
*.parquet
*.feather
*.xlsx
*.xls
!data/**/sample_*.csv
!data/**/*.example.csv
# Power BI dashboard marts are small aggregates — track them so the .pbip works on clone.
!powerbi/**/data/*.csv
# Power BI local/machine-specific cache (not part of the shared project)
**/.pbi/

# Trained ML models / pickles
models/
*.pkl
*.pickle
*.joblib
*.h5
*.model

# ---------------------------------------------------------------------------
# Databases (SQLite / local DB files)
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

