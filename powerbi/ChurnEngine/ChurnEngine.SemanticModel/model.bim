        "lineageTag": "d76a25f9-616e-4d13-bfee-370809b8f2b1",
        "measures": [
          {
            "name": "Scored Customers",
            "description": "Active customers assigned a 1-100 churn-risk score by the model.",
            "displayFolder": "3 Risk & Churn",
            "expression": "SUM(risk_distribution[customers])",
            "formatString": "#,0",
            "lineageTag": "7f597e81-29d0-4060-970e-8633ea0cf145"
          },
          {
            "name": "High-Risk Customers (80+)",
            "description": "Customers scoring 80 or above on the churn-risk model — the priority retention list.",
            "displayFolder": "3 Risk & Churn",
            "expression": "CALCULATE(SUM(risk_distribution[customers]), risk_distribution[score_lo] >= 80)",
            "formatString": "#,0",
            "lineageTag": "7d5de258-586c-45a0-aae4-488a9447d1d8"
          },
          {
            "name": "% High-Risk (80+)",
            "description": "Share of scored customers that fall in the high-risk band (score 80+).",
            "displayFolder": "3 Risk & Churn",
            "expression": "DIVIDE([High-Risk Customers (80+)], [Scored Customers])",
            "formatString": "0.0%",
            "lineageTag": "c0ffee01-0004-4a1a-9001-000000000004"
          },
          {
            "name": "Avg Churn Prob (High-Risk 80+)",
            "description": "Average modelled churn probability among customers scoring 80+.",
            "displayFolder": "3 Risk & Churn",
            "expression": "CALCULATE(AVERAGE(risk_distribution[avg_churn_prob]), risk_distribution[score_lo] >= 80)",
            "formatString": "0.0%",
            "lineageTag": "c0ffee01-0005-4a1a-9001-000000000005"
          }
        ],
        "partitions": [
