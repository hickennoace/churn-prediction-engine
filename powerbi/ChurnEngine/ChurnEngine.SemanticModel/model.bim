            "sourceColumn": "band",
            "summarizeBy": "none"
          },
          {
            "name": "score_lo",
            "dataType": "int64",
            "lineageTag": "b58714cf-36a4-4ebc-9d43-31aafdae2f7d",
            "sourceColumn": "score_lo",
            "summarizeBy": "none"
          },
          {
            "name": "active_customers",
            "dataType": "int64",
            "lineageTag": "ab740f9e-252f-4fd9-8f85-eb1d5d0974ce",
            "sourceColumn": "active_customers",
            "summarizeBy": "sum"
          },
          {
            "name": "mrr_in_band",
            "dataType": "double",
            "lineageTag": "b15e4f85-31c0-49a3-8542-4913d5c3cf40",
            "sourceColumn": "mrr_in_band",
            "summarizeBy": "sum"
          },
          {
            "name": "expected_monthly_revenue_at_risk",
            "dataType": "double",
            "lineageTag": "212a8db5-68f7-4f85-8984-28814a2916b2",
            "sourceColumn": "expected_monthly_revenue_at_risk",
            "summarizeBy": "sum"
          }
        ],
        "lineageTag": "c443ec0e-0ba2-4fee-be72-7f5e6861fa30",
        "measures": [
          {
            "name": "Revenue at Risk (NT$/mo)",
            "description": "Expected monthly recurring revenue lost = each band's MRR times its average churn probability.",
            "displayFolder": "3 Risk & Churn",
            "expression": "SUM(revenue_at_risk[expected_monthly_revenue_at_risk])",
            "formatString": "\"NT$\" #,0",
            "lineageTag": "79d02532-558e-42cf-859f-c7cfb81e7958"
          },
          {
            "name": "MRR Covered (NT$)",
            "description": "Total monthly recurring revenue across all scored risk bands.",
            "displayFolder": "3 Risk & Churn",
            "expression": "SUM(revenue_at_risk[mrr_in_band])",
            "formatString": "\"NT$\" #,0",
            "lineageTag": "8c66ff1b-c969-46a5-a19d-418a2d96a4af"
          },
          {
            "name": "% Revenue at Risk",
            "description": "Expected revenue at risk as a share of total scored MRR.",
            "displayFolder": "3 Risk & Churn",
            "expression": "DIVIDE([Revenue at Risk (NT$/mo)], [MRR Covered (NT$)])",
            "formatString": "0.0%",
            "lineageTag": "c0ffee01-0006-4a1a-9001-000000000006"
          },
          {
            "name": "Revenue Retained (NT$/mo)",
            "description": "Scored MRR expected to be retained = MRR covered minus revenue at risk.",
            "displayFolder": "3 Risk & Churn",
            "expression": "[MRR Covered (NT$)] - [Revenue at Risk (NT$/mo)]",
            "formatString": "\"NT$\" #,0",
            "lineageTag": "c0ffee01-0007-4a1a-9001-000000000007"
          },
          {
            "name": "Annual Revenue at Risk (NT$)",
            "description": "Expected revenue at risk annualised (monthly figure x12).",
            "displayFolder": "3 Risk & Churn",
            "expression": "[Revenue at Risk (NT$/mo)] * 12",
            "formatString": "\"NT$\" #,0",
            "lineageTag": "c0ffee01-0008-4a1a-9001-000000000008"
          }
        ],
        "partitions": [
          {
            "name": "revenue_at_risk",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(\"C:\\Users\\Daniel\\churn-prediction-engine\\powerbi\\ChurnEngine\\data\\revenue_at_risk.csv\"), [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    Typed = Table.TransformColumnTypes(Promoted, {{\"band\", Int64.Type}, {\"score_lo\", Int64.Type}, {\"active_customers\", Int64.Type}, {\"mrr_in_band\", type number}, {\"expected_monthly_revenue_at_risk\", type number}})",
                "in",
                "    Typed"
              ],
              "type": "m"
            }
          }
        ]
      },
